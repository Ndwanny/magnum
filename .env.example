# ============================================================
# Magnum Security — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Found at: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Lenco by Broadpay (Payment Gateway) ───────────────────────
# Register at: https://broadpay.io or https://lenco.co
# Use sandbox keys for development, live keys for production.
LENCO_BASE_URL=https://api.broadpay.io/v1
LENCO_API_KEY=bpk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
LENCO_MERCHANT_ID=MERCH_XXXXXXXXXXXX
LENCO_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Application ───────────────────────────────────────────────
# Production URL of the deployed app (used in payment redirect URLs)
APP_URL=https://portal.magnumsecurity.co.zm

# ── Resend (Email) ─────────────────────────────────────────────
# Used by the Supabase Edge Function send-email
# Set this in Supabase: supabase secrets set RESEND_API_KEY=re_xxx
# Register at: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@magnumsecurity.co.zm

# ── Cloudflare Pages (CI/CD) ───────────────────────────────────
# Set as GitHub repository secrets (not in this file)
# CLOUDFLARE_API_TOKEN — API token with Pages:Edit permission
# CLOUDFLARE_ACCOUNT_ID — found in Cloudflare dashboard
